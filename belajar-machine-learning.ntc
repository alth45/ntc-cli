## 🚀 Tahap 6 — Simpan Model & Deployment

### 6.1 Simpan & Load Model

```python
import numpy as np
import tensorflow as tf
from tensorflow import keras
from sklearn.ensemble import RandomForestClassifier
from sklearn.datasets import load_iris
from sklearn.model_selection import train_test_split
import joblib
import os

# =============================================
# Simpan & Load Model Scikit-learn
# =============================================
iris = load_iris()
X_train, X_test, y_train, y_test = train_test_split(
    iris.data, iris.target, test_size=0.2, random_state=42
)

rf = RandomForestClassifier(n_estimators=100, random_state=42)
rf.fit(X_train, y_train)

# Simpan model
joblib.dump(rf, 'model_rf_iris.pkl')
print("✅ Model sklearn tersimpan: model_rf_iris.pkl")

# Load model
rf_loaded = joblib.load('model_rf_iris.pkl')
acc = rf_loaded.score(X_test, y_test)
print(f"✅ Model dimuat! Test accuracy: {acc:.4f}")

# =============================================
# Simpan & Load Model Keras/TF
# =============================================
(X_train_mnist, y_train_mnist), (X_test_mnist, y_test_mnist) = keras.datasets.mnist.load_data()
X_train_mnist = X_train_mnist.reshape(-1, 784).astype('float32') / 255.0
X_test_mnist  = X_test_mnist.reshape(-1, 784).astype('float32') / 255.0

model = keras.Sequential([
    keras.Input(shape=(784,)),
    keras.layers.Dense(128, activation='relu'),
    keras.layers.Dense(10, activation='softmax')
])
model.compile(optimizer='adam', loss='sparse_categorical_crossentropy', metrics=['accuracy'])
model.fit(X_train_mnist, y_train_mnist, epochs=3, batch_size=256, verbose=0)

# Simpan format modern (.keras)
model.save('model_mnist.keras')
print("\n✅ Model Keras tersimpan: model_mnist.keras")

# Load model
model_loaded = keras.models.load_model('model_mnist.keras')
_, acc_tf = model_loaded.evaluate(X_test_mnist, y_test_mnist, verbose=0)
print(f"✅ Model dimuat! Test accuracy: {acc_tf:.4f}")

# Prediksi dengan model yang sudah dimuat
sample = X_test_mnist[:5]
preds  = model_loaded.predict(sample, verbose=0).argmax(axis=1)
actual = y_test_mnist[:5]
print(f"\nPrediksi: {preds}")
print(f"Aktual  : {actual}")
```

